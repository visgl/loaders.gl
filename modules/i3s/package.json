{
  "name": "@loaders.gl/i3s",
  "version": "4.4.0",
  "description": "i3s .",
  "license": "MIT",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/visgl/loaders.gl"
  },
  "keywords": [
    "webgl",
    "loader",
    "i3s",
    "tile",
    "mesh"
  ],
  "types": "dist/index.d.ts",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./bundled": {
      "types": "./dist/bundled.d.ts",
      "import": "./dist/bundled.js"
    },
    "./unbundled": {
      "types": "./dist/unbundled.d.ts",
      "import": "./dist/unbundled.js"
    },
    "./i3s-content-worker.js": {
      "import": "./dist/i3s-content-worker.js"
    },
    "./i3s-content-worker-node.js": {
      "import": "./dist/i3s-content-worker-node.js"
    },
    "./i3s-module.js": {
      "import": "./dist/i3s-module.js"
    },
    "./i3s-classic.js": {
      "browser": "./dist/i3s-classic.js",
      "require": "./dist/i3s-classic-node.cjs",
      "default": "./dist/i3s-classic.js"
    }
  },
  "sideEffects": false,
  "files": [
    "src",
    "dist",
    "README.md"
  ],
  "scripts": {
    "pre-build": "npm run build-bundle && npm run build-bundle-dev && npm run build-worker && npm run build-worker-node && npm run build-combined-worker && npm run build-combined-worker-classic && npm run build-combined-worker-node",
    "build-bundle": "ocular-bundle ./bundle.ts --output=dist/dist.min.js",
    "build-bundle-dev": "ocular-bundle ./bundle.ts --env=dev --output=dist/dist.dev.js",
    "build-worker": "esbuild src/workers/i3s-content-worker.ts --outfile=dist/i3s-content-worker.js --target=esnext --bundle --define:__VERSION__=\\\"$npm_package_version\\\"",
    "build-worker-node": "esbuild src/workers/i3s-content-worker-node.ts --outfile=dist/i3s-content-worker-node.js --platform=node --target=node16 --minify --bundle --sourcemap --define:__VERSION__=\\\"$npm_package_version\\\"",
    "build-combined-worker": "esbuild src/workers/i3s-module.ts --bundle --format=esm --outfile=dist/i3s-module.js --target=esnext --define:__VERSION__=\\\"$npm_package_version\\\"",
    "build-combined-worker-node": "esbuild src/workers/i3s-classic-node.ts --bundle --format=cjs --outfile=dist/i3s-classic-node.cjs --platform=node --target=node16 --define:__VERSION__=\\\"$npm_package_version\\\"",
    "build-combined-worker-classic": "esbuild src/workers/i3s-module.ts --bundle --format=iife --outfile=dist/i3s-classic.js --target=esnext --global-name=loaders.i3s --define:__VERSION__=\\\"$npm_package_version\\\""
  },
  "dependencies": {
    "@loaders.gl/compression": "4.4.0",
    "@loaders.gl/crypto": "4.4.0",
    "@loaders.gl/draco": "4.4.0",
    "@loaders.gl/images": "4.4.0",
    "@loaders.gl/loader-utils": "4.4.0",
    "@loaders.gl/math": "4.4.0",
    "@loaders.gl/schema": "4.4.0",
    "@loaders.gl/textures": "4.4.0",
    "@loaders.gl/tiles": "4.4.0",
    "@loaders.gl/zip": "4.4.0",
    "@math.gl/core": "^4.1.0",
    "@math.gl/culling": "^4.1.0",
    "@math.gl/geospatial": "^4.1.0"
  },
  "peerDependencies": {
    "@loaders.gl/core": "~4.4.0"
  },
  "gitHead": "8a9e77743ea90a7be4ebec572416bb50ca9d73c3"
}
