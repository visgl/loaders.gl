{
  "name": "@loaders.gl/shapefile",
  "description": "Loader for the Shapefile Format",
  "version": "4.4.0",
  "license": "MIT",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/visgl/loaders.gl"
  },
  "keywords": [
    "geometry",
    "loader",
    "parser",
    "shapefile",
    "shp"
  ],
  "types": "dist/index.d.ts",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./unbundled": {
      "types": "./dist/unbundled.d.ts",
      "import": "./dist/unbundled.js"
    },
    "./bundled": {
      "types": "./dist/bundled.d.ts",
      "import": "./dist/bundled.js"
    },
    "./shp-worker.js": {
      "import": "./dist/shp-worker.js"
    },
    "./dbf-worker.js": {
      "import": "./dist/dbf-worker.js"
    },
    "./shapefile-module.js": {
      "import": "./dist/shapefile-module.js"
    },
    "./shapefile-classic.js": {
      "browser": "./dist/shapefile-classic.js",
      "require": "./dist/shapefile-classic-node.cjs",
      "default": "./dist/shapefile-classic.js"
    }
  },
  "sideEffects": false,
  "browser": {
    "fs": false
  },
  "files": [
    "src",
    "dist",
    "README.md"
  ],
  "scripts": {
    "pre-build": "npm run build-worker-shp && npm run build-worker-dbf && npm run build-bundle && npm run build-bundle-dev && npm run build-combined-worker && npm run build-combined-worker-classic && npm run build-combined-worker-node",
    "build-bundle": "ocular-bundle ./bundle.ts --output=dist/dist.min.js",
    "build-bundle-dev": "ocular-bundle ./bundle.ts --env=dev --output=dist/dist.dev.js",
    "build-worker-shp": "esbuild src/workers/shp-worker.ts --bundle --outfile=dist/shp-worker.js --define:__VERSION__=\\\"$npm_package_version\\\"",
    "build-worker-dbf": "esbuild src/workers/dbf-worker.ts --bundle --outfile=dist/dbf-worker.js --define:__VERSION__=\\\"$npm_package_version\\\"",
    "build-combined-worker": "esbuild src/workers/shapefile-module.ts --bundle --format=esm --outfile=dist/shapefile-module.js --target=esnext --define:__VERSION__=\\\"$npm_package_version\\\"",
    "build-combined-worker-node": "esbuild src/workers/shapefile-module.ts --bundle --format=cjs --outfile=dist/shapefile-classic-node.cjs --platform=node --target=node16 --define:__VERSION__=\\\"$npm_package_version\\\"",
    "build-combined-worker-classic": "esbuild src/workers/shapefile-module.ts --bundle --format=iife --outfile=dist/shapefile-classic.js --target=esnext --global-name=loaders.shapefile --define:__VERSION__=\\\"$npm_package_version\\\""
  },
  "dependencies": {
    "@loaders.gl/gis": "4.4.0",
    "@loaders.gl/loader-utils": "4.4.0",
    "@loaders.gl/schema": "4.4.0",
    "@math.gl/proj4": "^4.1.0"
  },
  "peerDependencies": {
    "@loaders.gl/core": "~4.4.0"
  },
  "gitHead": "8a9e77743ea90a7be4ebec572416bb50ca9d73c3"
}
