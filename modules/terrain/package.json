{
  "name": "@loaders.gl/terrain",
  "version": "4.4.0",
  "description": "Framework-independent loader for terrain raster formats",
  "license": "MIT",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/visgl/loaders.gl"
  },
  "keywords": [
    "webgl",
    "loader",
    "3d",
    "mesh",
    "point cloud",
    "OBJ"
  ],
  "types": "dist/index.d.ts",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./bundled": {
      "types": "./dist/bundled.d.ts",
      "import": "./dist/bundled.js"
    },
    "./unbundled": {
      "types": "./dist/unbundled.d.ts",
      "import": "./dist/unbundled.js"
    },
    "./terrain-worker.js": {
      "import": "./dist/terrain-worker.js"
    },
    "./quantized-mesh-worker.js": {
      "import": "./dist/quantized-mesh-worker.js"
    },
    "./terrain-module.js": {
      "import": "./dist/terrain-module.js"
    },
    "./terrain-classic.js": {
      "browser": "./dist/terrain-classic.js",
      "require": "./dist/terrain-classic-node.cjs",
      "default": "./dist/terrain-classic.js"
    }
  },
  "sideEffects": false,
  "files": [
    "src",
    "dist",
    "README.md"
  ],
  "scripts": {
    "pre-build": "npm run build-worker && npm run build-worker2 && npm run build-bundle && npm run build-bundle-dev && npm run build-combined-worker && npm run build-combined-worker-classic && npm run build-combined-worker-node",
    "build-bundle": "ocular-bundle ./bundle.ts --output=dist/dist.min.js",
    "build-bundle-dev": "ocular-bundle ./bundle.ts --env=dev --output=dist/dist.dev.js",
    "build-worker": "esbuild src/workers/terrain-worker.ts --bundle --outfile=dist/terrain-worker.js --define:__VERSION__=\\\"$npm_package_version\\\"",
    "build-worker2": "esbuild src/workers/quantized-mesh-worker.ts --bundle --outfile=dist/quantized-mesh-worker.js --define:__VERSION__=\\\"$npm_package_version\\\"",
    "build-combined-worker": "esbuild src/workers/terrain-module.ts --bundle --format=esm --outfile=dist/terrain-module.js --target=esnext --define:__VERSION__=\\\"$npm_package_version\\\"",
    "build-combined-worker-node": "esbuild src/workers/terrain-module.ts --bundle --format=cjs --outfile=dist/terrain-classic-node.cjs --platform=node --target=node16 --define:__VERSION__=\\\"$npm_package_version\\\"",
    "build-combined-worker-classic": "esbuild src/workers/terrain-module.ts --bundle --format=iife --outfile=dist/terrain-classic.js --target=esnext --global-name=loaders.terrain --define:__VERSION__=\\\"$npm_package_version\\\""
  },
  "dependencies": {
    "@loaders.gl/images": "4.4.0",
    "@loaders.gl/loader-utils": "4.4.0",
    "@loaders.gl/schema": "4.4.0",
    "@loaders.gl/schema-utils": "4.4.0",
    "@mapbox/martini": "^0.2.0"
  },
  "peerDependencies": {
    "@loaders.gl/core": "~4.4.0"
  },
  "gitHead": "8a9e77743ea90a7be4ebec572416bb50ca9d73c3"
}
