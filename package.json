{
  "name": "loaders.gl",
  "description": "Framework-independent loaders for visualization, 3D graphics and geospatial formats",
  "license": "MIT",
  "type": "module",
  "private": true,
  "packageManager": "yarn@4.12.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/visgl/loaders.gl"
  },
  "keywords": [
    "webgl",
    "loader",
    "3d",
    "point cloud",
    "GLB",
    "OBJ",
    "PLY",
    "LAZ",
    "PCD",
    "KML"
  ],
  "workspaces": [
    "modules/*",
    "apps/*",
    "dev-modules/*",
    "examples/**",
    "website"
  ],
  "engines": {
    "node": ">=20.18.0"
  },
  "scripts": {
    "bootstrap": "ocular-bootstrap",
    "postinstall": "echo postinstall",
    "start": "echo 'Please see loaders.gl website for how to run examples' && open https://loaders.gl/docs",
    "serve-range": "node ./dev-modules/devtools-extensions/range-server.mjs",
    "clean": "ocular-clean",
    "tsclean": "find . -name tsconfig.tsbuildinfo -exec rm {} \\;",
    "build": "yarn build-modules",
    "build-modules": "ocular-clean && ocular-build && npx lerna run pre-build",
    "build-apps": "node ./scripts/run-app-commands.mjs build",
    "build-workers": "node ./scripts/build-workers.mjs",
    "cover": "yarn test-cover",
    "lint": "yarn workspace @loaders.gl/devtools-extensions lint",
    "publish-beta": "ocular-publish version-only-beta",
    "publish-prod": "ocular-publish version-only-prod",
    "test": "yarn test-modules",
    "test-modules": "node ./scripts/test.mjs",
    "test-apps": "node ./scripts/run-app-commands.mjs test",
    "test-node": "node ./scripts/test.mjs node",
    "test-browser": "node ./scripts/test.mjs browser",
    "test-headless": "node ./scripts/test.mjs browser-headless",
    "test-vitest-async-guardrails": "node ./scripts/check-vitest-async-guardrails.mjs",
    "playwright:install": "yarn workspace @loaders.gl/devtools-extensions playwright:install",
    "test-cover": "node ./scripts/test.mjs cover",
    "test-website": "cd website && yarn && yarn build && cd ..",
    "test-fast": "yarn lint && yarn test-node",
    "pre-commit": "yarn lint",
    "pre-push": "yarn lint",
    "metrics": "./scripts/metrics.sh && ocular-metrics"
  },
  "devDependencies": {
    "@loaders.gl/devtools-extensions": "workspace:*",
    "@probe.gl/bench": "^4.1.1",
    "@probe.gl/test-utils": "^4.1.1",
    "@types/node": "^25.3.0",
    "@types/tape-promise": "^4.0.1",
    "@vis.gl/dev-tools": "^1.0.0",
    "@vis.gl/ts-plugins": "^1.0.0",
    "@vitest/browser": "^4.0.18",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "playwright": "^1.59.1",
    "pre-commit": "^1.2.2",
    "pre-push": "^0.1.1",
    "tap-spec": "^5.0.0",
    "vite": "^8.0.0",
    "vitest": "^4.0.18"
  },
  "pre-commit": "pre-commit",
  "pre-push": "pre-push",
  "resolutions_notes": [
    "Ensure we use recent typescript",
    "apache-arrow version should be aligned with parquet-wasm version"
  ],
  "resolutions": {
    "apache-arrow": "^21.0.0",
    "typescript": "^5.6.0",
    "@loaders.gl/3d-tiles": "^4.4.0",
    "@loaders.gl/compression": "^4.4.0",
    "@loaders.gl/core": "^4.4.0",
    "@loaders.gl/crypto": "^4.4.0",
    "@loaders.gl/draco": "^4.4.0",
    "@loaders.gl/geopackage": "^4.4.0",
    "@loaders.gl/gis": "^4.4.0",
    "@loaders.gl/gltf": "^4.4.0",
    "@loaders.gl/images": "^4.4.0",
    "@loaders.gl/i3s": "^4.4.0",
    "@loaders.gl/las": "^4.4.0",
    "@loaders.gl/loader-utils": "^4.4.0",
    "@loaders.gl/math": "^4.4.0",
    "@loaders.gl/mvt": "^4.4.0",
    "@loaders.gl/obj": "^4.4.0",
    "@loaders.gl/ply": "^4.4.0",
    "@loaders.gl/sql": "^4.4.0",
    "@loaders.gl/schema": "^4.4.0",
    "@loaders.gl/schema-utils": "^4.4.0",
    "@loaders.gl/terrain": "^4.4.0",
    "@loaders.gl/textures": "^4.4.0",
    "@loaders.gl/tiles": "^4.4.0",
    "@loaders.gl/worker-utils": "^4.4.0",
    "@loaders.gl/wms": "^4.4.0",
    "@loaders.gl/zip": "^4.4.0"
  }
}
